# Adria Ledger Gitignore

# Data & State (Runtime created)
apl_data/
**/apl_data/
*.db
*.wallets
*.wallet
adria-config.json

# Zig Build Artifacts
zig-cache/
.zig-cache/
zig-out/
bench_data_consensus/

# Python Cache
__pycache__/
*.pyc

# Logs
*.log

# Test Artifacts
tests/*_addr.txt
*_addr.txt

# System / Editor
.DS_Store
.vscode/
.claude/
memory/
plan.md

# Debug Output
server_output.txt
tests/debug/

# Release Archives
dist/

# Temporary Test Data
apl_data_test/
apl_data_test_dos/
test_doc.json
diff_large.json
